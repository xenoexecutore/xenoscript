<!DOCTYPE html>
<html>
<head>
<title>Admin PowerShell Launcher</title>
<HTA:APPLICATION ID="launcher" APPLICATIONNAME="Admin PS" WINDOWSTATE="normal" SHOWINTASKBAR="yes" SINGLEINSTANCE="yes">
</head>
<script language="JavaScript">
    function openPowerShell() {
        var shell = new ActiveXObject("Shell.Application");
        // Launches PowerShell as admin, no additional commands
        shell.ShellExecute("powershell.exe", "", "", "runas", 1);
        window.close();
    }
    window.onload = openPowerShell;
</script>
<body style="background:#e0e0e0; text-align:center; padding:50px;">
    <h2>Launching PowerShell as Administrator...</h2>
</body>
</html>
